# Mapbox GL JS public token (get from https://mapbox.com/account)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxx

# Supabase (get from https://supabase.com/dashboard project settings)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Rentcast API (get from https://app.rentcast.io/app/api-keys)
RENTCAST_API_KEY=xxxxxxxxxx

# ArcGIS cancer data service URL (manually extracted from DevTools)
ARCGIS_CANCER_SERVICE_URL=https://services.arcgis.com/.../FeatureServer

# App config
NEXT_PUBLIC_DEFAULT_CENTER_LAT=29.7604
NEXT_PUBLIC_DEFAULT_CENTER_LNG=-95.3698
LISTING_CACHE_TTL_HOURS=168
RENTCAST_MONTHLY_LIMIT=45
